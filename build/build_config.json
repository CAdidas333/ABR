        {"setting": "CVRTolerance", "value": "0.01", "description": "Allowed dollar difference for CVR group sum", "valid_range": "0.00-1.00"},
        {"setting": "DateWindowDays", "value": "7", "description": "Maximum date difference to consider for matching", "valid_range": "3-30"},
        {"setting": "CurrentMonth", "value": "", "description": "Active reconciliation period (YYYY-MM)", "valid_range": "YYYY-MM format"},
        {"setting": "AutoStageHighConfidence", "value": "TRUE", "description": "Auto-stage matches above high threshold", "valid_range": "TRUE, FALSE"},
        {"setting": "MaxCVRFragments", "value": "6", "description": "Maximum fragments in a CVR group", "valid_range": "2-10"},
        {"setting": "MaxCVRCandidates", "value": "20", "description": "Maximum candidates to consider for CVR subset-sum", "valid_range": "10-50"},
        {"setting": "CVRTimeoutSeconds", "value": "2", "description": "Timeout for CVR subset-sum search", "valid_range": "1-10"}
